# Copy to .env and fill in. All values are exposed to the client (Vite VITE_*),
# so only use publishable/anon keys here.

# TMDB (Movies & TV Shows) — https://www.themoviedb.org/settings/api  (v3 API key)
VITE_TMDB_API_KEY=

# Supabase (Auth, Watchlist, Favorites, Ratings, Continue Watching)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
